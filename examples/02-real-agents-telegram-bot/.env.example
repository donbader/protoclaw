# Required: Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Override model (default set in protoclaw.yaml)
# OPENCODE_PROVIDER=anthropic
# OPENCODE_MODEL=claude-sonnet-4-20250514

# Telegram (optional — test with debug-http first)
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=your-bot-token-here
