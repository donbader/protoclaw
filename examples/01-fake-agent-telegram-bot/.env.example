# Required only when enabling Telegram channel:
# 1. Message @BotFather on Telegram, send /newbot
# 2. Copy the token here
# 3. Set PROTOCLAW_CHANNELS__1__ENABLED=true below
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Enable Telegram channel (disabled by default — test with debug-http first)
# PROTOCLAW_CHANNELS__1__ENABLED=true

# Override log level (default: debug)
# LOG_LEVEL=info
