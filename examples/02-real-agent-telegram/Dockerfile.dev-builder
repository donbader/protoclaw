# Dev base: compile anyclaw + ext binaries from workspace source.
# Shared across all agent variants — do not modify when adding a variant.
#
# Build context: workspace root
# Produces: anyclaw-dev-base:latest (binaries at /usr/local/bin/)
#
# Not invoked directly — each variant's Makefile builds this first.

FROM lukemathwalker/cargo-chef:latest-rust-1.94-alpine AS chef
WORKDIR /build
RUN apk add --no-cache clang mold

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /build/recipe.json recipe.json
COPY .cargo .cargo
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/build/target \
    cargo chef cook --locked --recipe-path recipe.json
COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/build/target \
    cargo build --locked \
    --bin anyclaw \
    --bin telegram-channel \
    --bin debug-http \
    --bin system-info \
    && mkdir -p /out/channels /out/tools \
    && cp target/debug/anyclaw /out/ \
    && cp target/debug/telegram-channel /out/channels/telegram \
    && cp target/debug/debug-http /out/channels/debug-http \
    && cp target/debug/system-info /out/tools/system-info

FROM scratch
COPY --from=builder /out/ /usr/local/bin/
